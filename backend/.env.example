SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DB_NAME=fms_db
DB_USER=fms_user
DB_PASSWORD=your-db-password-here
DB_HOST=localhost
DB_PORT=5432
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
REDIS_URL=redis://127.0.0.1:6379/1

# ---------------------------------------------------------------------------
# Railway production only — leave unset for local development.
# ---------------------------------------------------------------------------
# DATABASE_URL is injected automatically by Railway's Postgres addon; when
# it's present it takes priority over the DB_* vars above.
# DATABASE_URL=postgresql://user:pass@host:port/dbname

# Set to your Railway-issued backend domain once known, e.g.
# ALLOWED_HOSTS=backend-production-xxxx.up.railway.app
# CSRF_TRUSTED_ORIGINS=https://backend-production-xxxx.up.railway.app
# CORS_ALLOWED_ORIGINS=https://frontend-production-xxxx.up.railway.app

# Cloudinary — required in production so uploaded photos survive redeploys
# (Railway's filesystem is wiped on every deploy). Get this from your
# Cloudinary dashboard: cloudinary.com/console -> API Environment variable.
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
